
{
  "entities": {
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student enrolled in the TechXera Campus.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "enrollmentDate": { "type": "string", "format": "date-time" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "currentSemester": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "studentId", "firstName", "lastName", "email", "enrollmentDate", "isApproved", "status"]
    },
    "SupportInquiry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SupportInquiry",
      "type": "object",
      "description": "Represents a technical support inquiry sent by a student.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "resolved"] }
      },
      "required": ["id", "name", "email", "subject", "message", "timestamp", "status"]
    },
    "Exam": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exam",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "semester": { "type": "string" },
        "examDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["upcoming", "active", "completed"] },
        "totalMarks": { "type": "number" }
      },
      "required": ["id", "title", "semester", "examDate", "status", "totalMarks"]
    },
    "Result": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Result",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "examId": { "type": "string" },
        "subject": { "type": "string" },
        "semester": { "type": "string" },
        "marks": { "type": "number" },
        "marksObtained": { "type": "number" },
        "totalMarks": { "type": "number" },
        "grade": { "type": "string" },
        "examDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "subject", "semester", "marks", "marksObtained", "totalMarks", "grade", "examDate"]
    },
    "StudyMaterial": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyMaterial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "subject": { "type": "string" },
        "semester": { "type": "string" },
        "materialType": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "fileUrl", "subject", "semester", "materialType", "uploadDate"]
    },
    "Notice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" },
        "isUrgent": { "type": "boolean" }
      },
      "required": ["id", "title", "description", "publishDate", "isUrgent"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/students/{studentUid}",
        "definition": { "entityName": "Student" }
      },
      {
        "path": "/students/{studentUid}/results/{resultId}",
        "definition": { "entityName": "Result" }
      },
      {
        "path": "/exams/{examId}",
        "definition": { "entityName": "Exam" }
      },
      {
        "path": "/studyMaterials/{materialId}",
        "definition": { "entityName": "StudyMaterial" }
      },
      {
        "path": "/notices/{noticeId}",
        "definition": { "entityName": "Notice" }
      },
      {
        "path": "/support_inquiries/{inquiryId}",
        "definition": { "entityName": "SupportInquiry" }
      }
    ]
  }
}
