rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'rraghabbarik@gmail.com' ||
        exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == 'teacher' ||
          get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isAdminOrTeacher() {
      return isAdmin() || isTeacher();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /{path=**}/results/{resultId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrTeacher();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /students/{studentUid} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(studentUid) || isAdmin();
      allow update: if isOwner(studentUid) || isAdminOrTeacher();
      allow delete: if isAdmin();
      match /results/{resultId} {
        allow read: if isOwner(studentUid) || isAdminOrTeacher();
        allow write: if isAdminOrTeacher();
      }
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(teacherId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isAdminOrTeacher() || (
        isSignedIn() &&
        request.resource.data.studentUid == request.auth.uid &&
        request.resource.data.tokenUsed ==
          get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.dynamicToken
      );
      allow update, delete: if isAdminOrTeacher();
    }

    match /exams/{examId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /studyMaterials/{materialId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /support_inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdminOrTeacher();
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create, update: if isAdminOrTeacher();
      allow delete: if isAdmin();
      match /submissions/{submissionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /challengeResults/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrTeacher();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      match /progress/{progressDoc} {
        allow read, write: if isOwner(userId) || isAdminOrTeacher();
      }
      match /challengeProgress/{challengeId} {
        allow read, write: if isOwner(userId) || isAdminOrTeacher();
      }
    }

    match /roadmaps/{roadmapId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /certificates/{certId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isAdminOrTeacher()
      );
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrTeacher();
    }

    match /messages/{messageId} {
      allow read, write: if isAdmin();
    }

    match /internships/{internshipId} {
      allow create, update, delete: if isAdmin();
      allow read: if isAdmin() || (
        isSignedIn() &&
        resource.data.studentIds.hasAny([request.auth.uid])
      );
      match /content/{contentId} {
        allow create, update, delete: if isAdmin();
        allow read: if isAdmin() || (
          isSignedIn() &&
          get(/databases/$(database)/documents/internships/$(internshipId)).data.studentIds.hasAny([request.auth.uid])
        );
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
