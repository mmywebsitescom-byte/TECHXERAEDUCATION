rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /students/{studentUid} {
      allow get, list: if isOwner(studentUid) || isAdmin();
      allow create: if isOwner(studentUid) && request.resource.data.id == studentUid;
      allow update: if (isExistingOwner(studentUid) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();

      match /results/{resultId} {
        allow get, list: if isOwner(studentUid) || isAdmin();
        allow create: if isOwner(studentUid) && request.resource.data.studentId == studentUid;
        allow update: if (isExistingOwner(studentUid) && request.resource.data.studentId == resource.data.studentId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /studyMaterials/{materialId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow get: if isOwner(adminUid);
      allow list: if false;
      allow create: if isOwner(adminUid);
      allow update, delete: if false;
    }
  }
}