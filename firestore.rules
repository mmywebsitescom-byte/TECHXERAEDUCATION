
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isApproved(userId) {
      return get(/databases/$(database)/documents/students/$(userId)).data.isApproved == true;
    }

    match /students/{studentUid} {
      // Allow public fetching by ID for result lookups
      allow get: if true;
      allow list: if isAdmin() || request.query.limit == 1; 
      
      allow create: if isOwner(studentUid) && request.resource.data.id == studentUid && request.resource.data.isApproved == false;
      allow update: if (isExistingOwner(studentUid) && request.resource.data.id == resource.data.id && request.resource.data.isApproved == resource.data.isApproved) || isAdmin();
      allow delete: if isAdmin();

      match /results/{resultId} {
        // Results are public if you have the student's direct UID (which results page gets after verifying DOB)
        allow get, list: if true; 
        allow create, update, delete: if isAdmin();
      }
    }

    match /studyMaterials/{materialId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow get: if isOwner(adminUid);
      allow list: if false;
      allow create: if isOwner(adminUid);
      allow update, delete: if false;
    }
  }
}
