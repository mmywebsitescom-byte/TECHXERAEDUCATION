
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'rraghabbarik@gmail.com');
    }

    match /students/{studentUid} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isOwner(studentUid);
      allow update: if isOwner(studentUid) || isAdmin();
      allow delete: if isAdmin();

      match /results/{resultId} {
        allow get, list: if true;
        allow write: if isAdmin();
      }
    }

    match /exams/{examId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /studyMaterials/{materialId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /notices/{noticeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /support_inquiries/{inquiryId} {
      allow create: if true;
      allow read, list, delete, update: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
